# /**********************************************************
# * 文件名: 99-lockstep-ft601.rules
# * 日期: 2026-07-19
# * 版本: v1.0
# * 更新记录: 新增 FT601 普通用户访问规则。
# * 描述: 授权桌面会话和 plugdev 组通过 libusb 访问 0403:601f。
# **********************************************************/
SUBSYSTEM=="usb", ATTR{idVendor}=="0403", ATTR{idProduct}=="601f", MODE="0660", GROUP="plugdev", TAG+="uaccess"
