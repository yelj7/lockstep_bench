{
  "schema_version": "2.0",
  "decoder_version": "2.1.0.0",
  "implemented": [
    {"group":"ahb","source":"raw_signals","required":["htrans","hready","hresp","haddr","hwrite","hwdata","hrdata"],"behaviors":["ahb_transfer","stall","error_response"]},
    {"group":"uart","source":"raw_signals_or_rtl_frame_hint","required":["tx","rx","tx_toggle","rx_toggle"],"behaviors":["uart_frame"],"limitations":["raw_decode_uses_115200_8N1_sidecar_rate","parity_error_requires_metadata"]},
    {"group":"spi","source":"raw_signals","required":["sclk","mosi","miso","cs_n"],"behaviors":["spi_transfer","cs_frame"]},
    {"group":"can","source":"raw_signals","required":["rx","tx","activity"],"behaviors":["can_activity"],"limitations":["frame_fields_require_bitrate_and_protocol_monitor"]},
    {"group":"i2c","source":"raw_signals","required":["scl","sda","start","stop","ack"],"behaviors":["start","stop","i2c_transfer","ack_nack"]},
    {"group":"eth","source":"rtl_frame_hint","required":["tx_en","rx_dv","frame_start","frame_end","ethertype"],"behaviors":["eth_frame","receive_error","transmit_error"]},
    {"group":"usb","source":"design_gap","required":["real_source"],"behaviors":["usb_reset","usb_packet"]},
    {"group":"jtag","source":"raw_signals","required":["tck","tms","tdi","tdo"],"behaviors":["jtag_cycle","tap_state","jtag_scan","reset"]},
    {"group":"mismatch","source":"raw_signals","required":["mismatch[4:0]"],"behaviors":["mismatch_event","fault_diff"]}
  ],
  "synthetic_policy": "unavailable_design_gap_without_source_evidence",
  "hardware_follow_up": {
    "uart": "freeze baud/format metadata or keep tx_byte/rx_byte frame hints",
    "can": "freeze bitrate/sample-point metadata or keep sof/eof/id frame hints",
    "eth": "capture MII/RMII clock or keep frame_start/frame_end/ethertype hints",
    "usb": "connect a real PHY source before enabling decode"
  }
}
