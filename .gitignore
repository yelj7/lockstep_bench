# /**********************************************************
# * 文件名: .gitignore
# * 日期: 2026-07-06
# * 版本: v1.1
# * 更新记录: 忽略银河麒麟离线环境套件、DEB 输入和环境锁文件
# * 描述: 忽略本地构建产物、IDE 临时文件和运行生成物
# **********************************************************/

# CMake build directories
build/
build-*/
cmake-build-*/
out/
software/lockstep_host/build-*/
!/hardware/noelv_zcu102_overlay/build/
!/hardware/noelv_zcu102_overlay/build/**

# CMake generated files outside dedicated build dirs
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
build.ninja
.ninja_deps
.ninja_log
*_autogen/

# Compiler and linker outputs
*.a
*.dll
*.dylib
*.exe
*.lib
*.obj
*.o
*.pdb
*.so

# IDE and editor state
.vs/
.vscode/
*.user
*.swp
*~

# Local runtime output
/logs/
/tmp/
/.codex-tasks/
/software/lockstep_host/logs/
/software/lockstep_host/tmp/
/software/lockstep_host/packaging/windows/logs/
/software/lockstep_host/packaging/windows/driver-backup/

# Offline build environment and package deliverables
/software/lockstep_host/debs/
/software/lockstep_host/offline-build-env/
/software/lockstep_host/dist/
/software/lockstep_host/build-environment.lock.json

# Vivado/XSim local work products
/.Xil/
/xsim.dir/
/vivado*.jou
/vivado*.log
/xvlog.log
/xvlog.pb
.codex-tasks/**/.Xil/
.codex-tasks/**/xsim.dir/

# Local dependency download cache; installed tools are kept separately
/.tools/downloads/
/.tools/
